---
import BaseLayout from '@/layouts/BaseLayout.astro';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: '贵州森境自然教育公园',
  description: '园区免费对外开放。团体活动及特色体验项目按项目另行收费，请提前电话预约。',
  publicAccess: true,
  isAccessibleForFree: true,
};
---
<BaseLayout
  title="入园须知"
  description="贵州森境自然教育公园免费对外开放，无需门票。团体活动（团建/研学/婚庆摄影）及特色体验项目按项目另行收费。贵阳出发约50分钟车程，开放时间09:00-17:30。"
  jsonLd={orgJsonLd}
>
  <h1 class="mb-8 font-display text-3xl font-bold text-warm-800 sm:text-4xl">入园须知</h1>

  <section class="rounded-3lg bg-white p-8 shadow-card">
    <h2 class="font-serif text-xl font-bold text-primary-600">入园方式</h2>
    <p class="mt-3 text-lg leading-relaxed text-warm-600">
      园区免费对外开放，无需门票。
    </p>
    <p class="mt-3 leading-relaxed text-warm-600">
      团体活动（团建、研学、婚庆摄影）及特色体验项目（蝴蝶探索营、标本课程等）按项目另行收费，请提前电话预约。
    </p>
  </section>

  <section class="mt-6 rounded-3lg bg-white p-8 shadow-card">
    <h2 class="font-serif text-xl font-bold text-secondary-600">交通指南</h2>
    <p class="mt-3 leading-relaxed text-warm-600">
      园区位于贵阳市修文县放马坪（朝阳村附近），从贵阳市区出发约 50 分钟车程。
      导航搜索「修文鑫鸿彬植物园」或「贵州森境自然教育公园」即可到达。
    </p>
  </section>

  <section class="mt-6 rounded-3lg bg-white p-8 shadow-card">
    <h2 class="font-serif text-xl font-bold text-secondary-600">开放时间</h2>
    <p class="mt-3 font-display text-2xl font-bold text-warm-700">09:00 - 17:30</p>
    <p class="mt-2 text-sm text-warm-400">全年开放，如遇极端天气或园区维护，将提前公告调整。</p>
  </section>

  <section class="mt-6 rounded-3lg bg-white p-8 shadow-card">
    <h2 class="font-serif text-xl font-bold text-secondary-600">温馨提示</h2>
    <ul class="mt-3 space-y-2.5 text-warm-600">
      <li class="flex items-start gap-2">
        <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-400"></span>
        团体活动（10 人以上）建议提前电话预约，以便安排导览与餐饮服务。
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-400"></span>
        蝴蝶温室为恒温环境，参观时请勿伸手触碰蝴蝶或植物。
      </li>
      <li class="flex items-start gap-2">
        <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary-400"></span>
        园区提供停车场、洗手间与饮水设施，建议穿着舒适徒步鞋。
      </li>
    </ul>
  </section>
</BaseLayout>
