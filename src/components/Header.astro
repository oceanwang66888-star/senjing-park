---
import { site } from '@/data/site';

const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: '首页' },
  { href: '/nature-education', label: '自然教育' },
  { href: '/team-building', label: '企业团建' },
  { href: '/wedding', label: '婚庆摄影' },
  { href: '/cuisine', label: '簸箕宴' },
  { href: '/park-guide', label: '园区导览' },
  { href: '/tickets', label: '入园须知' },
  { href: '/news', label: '活动资讯' },
  { href: '/faq', label: '常见问题' },
  { href: '/about', label: '关于我们' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 transition-all duration-300" id="site-header">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <span class="font-serif text-xl font-bold tracking-wide text-primary-700 lg:text-2xl">
        {site.brandName}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 lg:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-200 ${
            isActive(item.href)
              ? 'bg-primary-50 text-primary-700'
              : 'text-warm-600 hover:bg-cream-100 hover:text-primary-600'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden rounded-full bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-soft transition-all duration-200 hover:bg-accent-600 hover:shadow-soft-md lg:inline-block"
      >
        预约咨询
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="flex flex-col gap-1.5 p-2 lg:hidden"
        aria-label="菜单"
      >
        <span class="block h-0.5 w-6 rounded-full bg-warm-700 transition-transform"></span>
        <span class="block h-0.5 w-6 rounded-full bg-warm-700"></span>
        <span class="block h-0.5 w-6 rounded-full bg-warm-700 transition-transform"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden border-t border-cream-200 bg-white/95 backdrop-blur-md lg:hidden"
  >
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4">
      {nav.map((item) => (
        <a
          href={item.href}
          class={`rounded-lg px-3 py-2.5 text-sm font-medium transition-colors ${
            isActive(item.href)
              ? 'bg-primary-50 text-primary-700'
              : 'text-warm-600 hover:bg-cream-100 hover:text-primary-600'
          }`}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 block rounded-full bg-accent px-5 py-2.5 text-center text-sm font-medium text-white shadow-soft"
      >
        预约咨询
      </a>
    </nav>
  </div>
</header>

<script>
  // 滚动时 Header 背景渐变不透明
  const header = document.getElementById('site-header');
  let scrolled = false;
  window.addEventListener('scroll', () => {
    const shouldScroll = window.scrollY > 20;
    if (shouldScroll !== scrolled) {
      scrolled = shouldScroll;
      if (scrolled) {
        header.classList.add('bg-cream-50/90', 'backdrop-blur-lg', 'shadow-soft');
      } else {
        header.classList.remove('bg-cream-50/90', 'backdrop-blur-lg', 'shadow-soft');
      }
    }
  });

  // 移动端菜单切换
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
